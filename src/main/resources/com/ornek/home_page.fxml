<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ornek.HomeController"
            prefWidth="1000.0" prefHeight="700.0"
            style="-fx-background-color: #f0f2f5; -fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif;">

    <!-- Yan Menü (Sidebar) -->
    <left>
        <VBox spacing="15" style="-fx-background-color: #1c1e21; -fx-padding: 20;" prefWidth="200">
            <Label text="PsikoAI" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Separator opacity="0.3"/>
            <Button text="Anasayfa" onAction="#showHomeView" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: transparent; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Günlük" onAction="#showJournalView" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #b0b3b8; -fx-border-color: transparent; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="Hesap Ayarları" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #b0b3b8; -fx-border-color: transparent; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="3D Meditasyon" onAction="#showMeditationView" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #fdbb2d; -fx-border-color: transparent; -fx-font-weight: bold; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Region VBox.vgrow="ALWAYS" />
            <Button fx:id="emergencyBtn" text="Acil Destek" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 24; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- Ana İçerik Alanı -->
    <center>
        <StackPane fx:id="rootStackPane">
            <VBox fx:id="mainContent" spacing="20" style="-fx-padding: 30;" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <HBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 8 15; -fx-background-radius: 25; -fx-border-color: #e4e6eb; -fx-border-radius: 25;">
                        <Label fx:id="userFullNameLabel" text="Kullanıcı Adı" style="-fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                        <Label text="👤" style="-fx-font-size: 20px; -fx-text-fill: #1877f2; -fx-background-color: #e7f3ff; -fx-background-radius: 50; -fx-padding: 5;"/>
                    </HBox>
                </HBox>

                <VBox spacing="5">
                    <Label text="Hoş geldin!" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                    <Label text="PsikoAI ile zihinsel sağlığını takip et." style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 20, 0, 0, 5);">
                    <VBox spacing="5">
                        <Label text="Son Testlerim" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                        <Label text="Detaylar için çift tıklayın" style="-fx-font-size: 12px; -fx-text-fill: #606770;"/>
                    </VBox>
                    
                    <StackPane prefHeight="200">
                        <TableView fx:id="resultsTable" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;">
                            <columns>
                                <TableColumn fx:id="dateColumn" text="Tarih" prefWidth="150">
                                    <cellValueFactory><PropertyValueFactory property="date"/></cellValueFactory>
                                </TableColumn>
                                <TableColumn fx:id="testNameColumn" text="Test" prefWidth="100">
                                    <cellValueFactory><PropertyValueFactory property="testName"/></cellValueFactory>
                                </TableColumn>
                                <TableColumn fx:id="gsiColumn" text="GSI" prefWidth="80">
                                    <cellValueFactory><PropertyValueFactory property="gsiScore"/></cellValueFactory>
                                </TableColumn>
                                <TableColumn fx:id="actionColumn" text="İşlemler" prefWidth="60" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>

                        <!-- Veri Yok Mesajı -->
                        <Label fx:id="noDataLabel" text="Henüz bir testiniz bulunmuyor." 
                               style="-fx-font-size: 14px; -fx-text-fill: #606770;" visible="false"/>
                    </StackPane>
                </VBox>
            </VBox>

            <!-- Günlük Görünümü -->
            <VBox fx:id="journalContent" spacing="20" style="-fx-padding: 30;" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <VBox spacing="5">
                    <Label text="Kişisel Günlüğüm" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                    <Label text="Düşüncelerini kaydetmek için bir tarih seç." style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                </VBox>

                <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 20, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label text="Tarih Seç:" style="-fx-font-size: 14px; -fx-text-fill: #606770; -fx-font-weight: bold;"/>
                        <DatePicker fx:id="journalDatePicker" onAction="#loadJournalEntry" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dddfe2; -fx-border-width: 1; -fx-background-color: #f5f6f7; -fx-padding: 5;"/>
                    </HBox>
                    
                    <TextArea fx:id="journalTextArea" VBox.vgrow="ALWAYS" promptText="Bugün neler oldu? Neler hissediyorsun?" wrapText="true" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dddfe2; -fx-border-width: 1; -fx-background-color: #f5f6f7; -fx-padding: 10; -fx-font-size: 14px;"/>
                    
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label fx:id="journalStatusLabel" text="" style="-fx-font-size: 12px; -fx-text-fill: #606770;"/>
                        <Button text="Günlüğü Kaydet" onAction="#saveJournal" style="-fx-min-width: 150; -fx-background-color: #1877f2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- Sağ Alttaki Yüzen Buton -->
            <VBox alignment="BOTTOM_RIGHT" pickOnBounds="false">
                <padding><Insets bottom="30" right="30"/></padding>
                <Button onAction="#showFeelingPanel" style="-fx-background-radius: 50; -fx-padding: 15; -fx-font-size: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 0); -fx-background-color: #1877f2; -fx-text-fill: white; -fx-cursor: hand;" text="💭" />
            </VBox>

            <!-- Test Detay Paneli -->
            <VBox fx:id="detailPanel" style="-fx-background-color: rgba(0,0,0,0.4);" visible="false" managed="false">
                <padding><Insets top="40" bottom="40" left="60" right="60"/></padding>
                
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 20, 0, 0, 5); -fx-max-width: 800; -fx-alignment: center;" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <Button text="← Geri Dön" onAction="#hideDetails" style="-fx-background-color: transparent; -fx-text-fill: #1877f2; -fx-border-color: #1877f2; -fx-border-radius: 8; -fx-border-width: 1; -fx-cursor: hand;"/>
                        <Label fx:id="detailTitleLabel" text="Test Analiz Detayları" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                    </HBox>
                    <Separator/>
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                        <GridPane hgap="20" vgap="12" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e4e6eb; -fx-border-radius: 10;">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                                <ColumnConstraints hgrow="NEVER" minWidth="80" prefWidth="100" />
                            </columnConstraints>
                            <Label text="Somatizasyon:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="somatizationField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Anksiyete:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="anxietyField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Obsesif-Kompulsif:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="obsessionField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Depresyon:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="depressionField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            <Label text="Kişilerarası Duyarlılık:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <TextField fx:id="sensitivityField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            <Label text="Psikotizm:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <TextField fx:id="psychoticismField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                            <Label text="Paranoid Düşünce:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <TextField fx:id="paranoidField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                            <Label text="Öfke-Hostilite:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                            <TextField fx:id="hostilityField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                            <Label text="Fobik Anksiyete:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                            <TextField fx:id="phobicField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="8" GridPane.columnIndex="1"/>
                            <Label text="Ek Maddeler:" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #4b4f56;" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                            <TextField fx:id="additionalField" editable="false" style="-fx-background-color: #f0f2f5; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="9" GridPane.columnIndex="1"/>
                            <Label text="Genel Semptom İndeksi (GSI):" style="-fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #1877f2;" GridPane.rowIndex="10" GridPane.columnIndex="0" />
                            <TextField fx:id="gsiField" editable="false" style="-fx-background-color: #e7f3ff; -fx-text-fill: #1877f2; -fx-border-color: transparent; -fx-font-weight: bold; -fx-alignment: center;" GridPane.rowIndex="10" GridPane.columnIndex="1"/>
                        </GridPane>
                    </ScrollPane>
                    <Separator/>
                    <VBox spacing="10" alignment="CENTER">
                        <Button fx:id="aiAnalyzeBtn" text="🤖 Yapay Zeka Analizi Oluştur" onAction="#handleAIAnalysis" 
                                style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                        <TextArea fx:id="aiAnalysisResultArea" visible="false" managed="false" editable="false" 
                                  wrapText="true" prefHeight="200" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dddfe2; -fx-border-width: 1; -fx-background-color: #f5f6f7; -fx-padding: 10; -fx-font-size: 14px;" promptText="Yapay zeka analizi burada görünecek..."/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Nasıl Hissediyorsunuz Paneli -->
            <VBox fx:id="feelingPanel" style="-fx-background-color: rgba(0,0,0,0.5);" visible="false" managed="false">
                <padding><Insets top="50" bottom="50" left="100" right="100"/></padding>
                <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 20, 0, 0, 5); -fx-max-width: 600;" alignment="TOP_CENTER">
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="✕" onAction="#hideFeelingPanel" style="-fx-background-color: transparent; -fx-text-fill: #adb5bd; -fx-font-size: 18px; -fx-cursor: hand;"/>
                    </HBox>
                    <Label text="Bugün Nasıl Hissediyorsun?" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                    
                    <FlowPane hgap="10" vgap="10" alignment="CENTER">
                        <Button text="😇 Mutlu" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="🤯 Kaygılı" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="🥀 Depresif" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="🌪️ Öfkeli" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="🧘 Huzurlu" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                        <Button text="😵 Sıkışmış" onAction="#handleFeelingSelect" style="-fx-background-color: #f0f2f5; -fx-text-fill: #1c1e21; -fx-border-color: transparent; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;"/>
                    </FlowPane>

                    <Label text="Biraz daha detay vermek ister misin? (İsteğe bağlı)" style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                    <TextArea fx:id="feelingNotesArea" prefHeight="150" promptText="Neler hissettiğini buraya yazabilirsin..." wrapText="true" style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #dddfe2; -fx-border-width: 1; -fx-background-color: #f5f6f7; -fx-padding: 10; -fx-font-size: 14px;"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="charCountLabel" text="0 / 500 kelime" style="-fx-font-size: 12px; -fx-text-fill: #606770;"/>
                    </HBox>

                    <Button text="Kaydet" onAction="#saveFeeling" style="-fx-min-width: 150; -fx-background-color: #1877f2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </VBox>
            </VBox>
            
            <!-- Meditasyon Görünümü (Saf JavaFX Container) -->
            <VBox fx:id="meditationContent" spacing="20" style="-fx-padding: 0; -fx-background-color: #0a0a0c;" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <!-- Meditasyon animasyonu HomeController tarafından buraya eklenecek -->
            </VBox>

            <!-- Kriz Katmanı (Programatik Olarak CrisisScreen.fxml Yüklenir) -->
            <StackPane fx:id="crisisLayer" pickOnBounds="false" alignment="TOP_RIGHT">
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
