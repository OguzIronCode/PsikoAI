<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.ornek.TestPageController"
           prefWidth="800.0" prefHeight="600.0"
           style="-fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif; -fx-background-color: #f0f2f5; -fx-padding: 20; -fx-alignment: center;">

    <VBox spacing="30" alignment="CENTER" fillWidth="false">
        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 20, 0, 0, 5);" alignment="CENTER" spacing="25" prefWidth="500">
            <!-- Başlık ve İlerleme -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="SCL-90 Belirti Tarama Testi" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1c1e21;"/>
                <Label fx:id="progressLabel" text="Soru 1 / 90" style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                <ProgressBar fx:id="progressBar" progress="0.0" maxWidth="Infinity"/>
            </VBox>

            <Separator/>

            <!-- Soru Alanı -->
            <VBox fx:id="questionContainer" alignment="CENTER_LEFT" spacing="20" minHeight="150" visible="false" managed="false">
                <Label fx:id="questionLabel" text="Soru metni buraya gelecek..." 
                       style="-fx-font-size: 16px; -fx-font-weight: bold;" wrapText="true" />
                
                <VBox spacing="10">
                    <fx:define>
                        <ToggleGroup fx:id="answerGroup"/>
                    </fx:define>
                    <RadioButton fx:id="opt0" text="Hiç (0)" toggleGroup="$answerGroup" />
                    <RadioButton fx:id="opt1" text="Biraz (1)" toggleGroup="$answerGroup" />
                    <RadioButton fx:id="opt2" text="Orta derecede (2)" toggleGroup="$answerGroup" />
                    <RadioButton fx:id="opt3" text="Oldukça fazla (3)" toggleGroup="$answerGroup" />
                    <RadioButton fx:id="opt4" text="İleri derecede (4)" toggleGroup="$answerGroup" />
                </VBox>
                
                <Button fx:id="nextButton" text="Sonraki Soru" onAction="#handleNext" maxWidth="Infinity" style="-fx-base: #1877f2; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <!-- Başlangıç Ekranı -->
            <VBox fx:id="startContainer" alignment="CENTER" spacing="20">
                <Label text="Aşağıdaki maddeler insanların bazen sahip oldukları şikayetleri içermektedir. Lütfen her birini dikkatle okuyun ve son BİR AY içinde bu şikayetin sizi ne kadar rahatsız ettiğini belirtin." 
                       wrapText="true" textAlignment="CENTER" style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                <Button text="Testi Başlat" onAction="#handleStartTest" maxWidth="200" style="-fx-base: #1877f2; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
                
                <HBox alignment="BOTTOM_RIGHT" spacing="10">
                    <padding><Insets top="20" /></padding>
                    <Button fx:id="skipButton" text="Testi Geç" onAction="#goToHomePage" 
                            style="-fx-background-color: transparent; -fx-text-fill: #1877f2; -fx-border-color: #1877f2; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10 20; -fx-cursor: hand;" visible="true" managed="true"/>
                </HBox>
            </VBox>

            <!-- Bitiş Ekranı -->
            <VBox fx:id="finishContainer" alignment="CENTER" spacing="20" visible="false" managed="false">
                <Label text="Testi Tamamladınız!" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;"/>
                <Label text="Sonuçlarınız başarıyla kaydedildi." style="-fx-font-size: 14px; -fx-text-fill: #606770;"/>
                <Button text="Anasayfaya Git" onAction="#goToHomePage" maxWidth="200" style="-fx-base: #1877f2; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
