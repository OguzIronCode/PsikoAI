<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.ornek.CrisisScreenController"
           style="-fx-background-color: #fdf8f5;" prefWidth="1000.0" prefHeight="700.0">
    <VBox alignment="CENTER" spacing="20">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        
        <Label text="Acil Destek ve Kriz Yönetimi" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
        <Label style="-fx-font-size: 16px; -fx-text-fill: #7f8c8d; -fx-text-alignment: center;" wrapText="true"
               text="Şu an zor bir an yaşıyor olabilirsin. Derin bir nefes al, yalnız değilsin. Aşağıdaki seçeneklerden sana en uygun olanı kullanabilirsin." />
        
        <Button fx:id="contactExpertBtn" text="Hemen Bir Uzmanla Görüş" style="-fx-font-size: 24px; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 20 50; -fx-cursor: hand;" />
        
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10 0 10 0;">
            <Button text="112 Acil" onAction="#call112" style="-fx-font-size: 18px; -fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 15 30; -fx-cursor: hand;" />
            <Button text="155 Polis" onAction="#call155" style="-fx-font-size: 18px; -fx-background-color: #2980b9; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 15 30; -fx-cursor: hand;" />
            <Button text="182 MHRS" onAction="#call182" style="-fx-font-size: 18px; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 15 30; -fx-cursor: hand;" />
        </HBox>
        
        <HBox alignment="CENTER" spacing="20">
            <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Sakinleşme Egzersizleri" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Button text="4-7-8 Nefes Egzersizi" onAction="#startBreathing" style="-fx-background-color: #ecf0f1; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button text="5-4-3-2-1 Topraklanma" onAction="#startGrounding" style="-fx-background-color: #ecf0f1; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Label fx:id="exerciseGuideLabel" text="" style="-fx-text-fill: #34495e; -fx-font-style: italic; -fx-padding: 10 0 0 0;" wrapText="true" maxWidth="250" alignment="CENTER" textAlignment="CENTER" />
            </VBox>
            
            <VBox alignment="CENTER" spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                <Label text="Güvenlik Planı" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="contactNameField" promptText="Kişi Adı" />
                    <TextField fx:id="contactPhoneField" promptText="Telefon (5XXXXXXXXX)" />
                    <Button text="Kaydet" onAction="#saveContact" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 5;" />
                </HBox>
                <Button text="Güvenilir Kişiye WhatsApp'tan Mesaj At" onAction="#sendWhatsAppMessage" style="-fx-background-color: #25D366; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
                <Button text="En Yakın Psikiyatri/Kriz Merkezi" onAction="#openMap" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;" />
            </VBox>
        </HBox>
        
        <Button text="Kapat ve Geri Dön" onAction="#closeCrisisScreen" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-underline: true; -fx-cursor: hand; -fx-padding: 20 0 0 0;" />
    </VBox>
</StackPane>
